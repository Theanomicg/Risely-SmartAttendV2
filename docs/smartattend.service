[Unit]
Description=SmartAttend v2 Backend
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/smartattend/backend
Environment=PATH=/var/www/smartattend/backend/venv/bin
ExecStart=/var/www/smartattend/backend/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=smartattend

[Install]
WantedBy=multi-user.target
