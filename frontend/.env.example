# ── SmartAttend Frontend — Environment ────────────────────────────────────────
# Copy to .env and fill in your values

# Backend API URL (leave blank to use Vite proxy on localhost)
# For production with a domain: https://api.yourdomain.com
VITE_API_URL=

# WebSocket URL for live alerts
# For production: wss://api.yourdomain.com/ws
VITE_WS_URL=

# Kiosk API Key (must match backend KIOSK_API_KEY)
VITE_KIOSK_API_KEY=CHANGE_ME_kiosk_secret_key
