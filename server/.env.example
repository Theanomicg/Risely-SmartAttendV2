# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=SmartAttend
DEBUG=false

# ── Database (SQLite — file path) ────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./smartattend.db

# ── JWT Secret (generate: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=CHANGE_ME_RUN_python_secrets_token_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Kiosk API key ─────────────────────────────────────────────────────────────
KIOSK_API_KEY=CHANGE_ME_KIOSK_SECRET

# ── Face Recognition (InsightFace) ───────────────────────────────────────────
FACE_MODEL=buffalo_l           # buffalo_l | buffalo_s (lighter)
FACE_THRESHOLD=0.35            # cosine similarity — higher = stricter (0.3–0.5)
FACE_ENROLLMENT_SAMPLES=5      # photos required per student

# ── Camera Monitoring ─────────────────────────────────────────────────────────
# Monitoring snapshot interval (seconds) — every 5 min = 300
MONITORING_INTERVAL=300
# Seconds absent before WARNING alert + bell (15 min)
ABSENT_WARNING_SECONDS=900
# Seconds absent before EMAIL alert (20 min)
ABSENT_EMAIL_SECONDS=1200

# ── Zoho SMTP ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.zoho.in
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASSWORD=your_zoho_app_password
SMTP_FROM_NAME=SmartAttend Alerts

# Alert email recipients (up to 3, comma-separated)
ALERT_EMAILS=admin@yourdomain.com,principal@yourdomain.com

# ── Daily report time (HH:MM, IST) ───────────────────────────────────────────
DAILY_REPORT_TIME=18:00

# ── Frontend / CORS ───────────────────────────────────────────────────────────
# Your deployed frontend domain (used for CORS)
FRONTEND_URL=https://smartattend.yourdomain.com
