# ── SmartAttend v2 — Environment Configuration ────────────────────────────────
# Copy this to .env and fill in your values.
# Run: cp .env.example .env

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=SmartAttend
DEBUG=false
SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
KIOSK_API_KEY=CHANGE_ME_kiosk_secret_key

# ── Database (SQLite — no setup needed) ──────────────────────────────────────
# For production PostgreSQL: postgresql+asyncpg://user:pass@host:5432/smartattend
DATABASE_URL=sqlite+aiosqlite:///./smartattend.db

# ── JWT ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Face Recognition (InsightFace) ───────────────────────────────────────────
FACE_MODEL=buffalo_l         # buffalo_l (accurate) | buffalo_s (fast)
FACE_THRESHOLD=0.45          # Cosine similarity — higher = stricter
FACE_ENROLLMENT_SAMPLES=5    # Photos required per student

# ── Monitoring ────────────────────────────────────────────────────────────────
MONITORING_INTERVAL_SECONDS=300    # Snapshot every 5 minutes
ABSENT_WARN_MINUTES=15             # Alert after 15 min missing
ABSENT_EMAIL_MINUTES=20            # Email after 20 min missing

# ── CORS / Frontend ───────────────────────────────────────────────────────────
# Your domain (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# ── Zoho SMTP ─────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.zoho.in
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASSWORD=your_zoho_app_password
SMTP_FROM_NAME=SmartAttend Alerts

# ── Alert Email Recipients (up to 3, comma-separated) ─────────────────────────
ALERT_EMAIL_RECIPIENTS=principal@school.com,admin@school.com,coordinator@school.com

# ── Daily Report ──────────────────────────────────────────────────────────────
DAILY_REPORT_TIME=18:00
DAILY_REPORT_RECIPIENTS=principal@school.com

# ── Snapshots directory ───────────────────────────────────────────────────────
SNAPSHOTS_DIR=./snapshots
